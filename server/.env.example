ENVIRONMENT=development
DEBUG=true

# Database
POSTGRES_USER=appsec
POSTGRES_PASSWORD=changeme
POSTGRES_DB=appsec
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://appsec:changeme@postgres:5432/appsec
DATABASE_URL_SYNC=postgresql+psycopg2://appsec:changeme@postgres:5432/appsec

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_SECRET_KEY=super-secret-change-me-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# App
APP_NAME=AppSec SaaS
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Domain verification
VERIFICATION_TOKEN_PREFIX=appsec-verify
VERIFICATION_TTL_DAYS=90

# AI scan summaries (OpenRouter) — optional; falls back to a deterministic
# summary if unset or rate-limited.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Quick-scan demo bypass. Set to true ONLY for demos — allows skip_verification
# on POST /api/v1/quick-scan. Never enable in production.
ALLOW_DEMO_VERIFICATION_SKIP=false

# urlscan.io engine — required for the urlscan scanner to run.
URLSCAN_API_KEY=
