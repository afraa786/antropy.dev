ENVIRONMENT=development
DEBUG=true

# Database
POSTGRES_USER=appsec
POSTGRES_PASSWORD=changeme
POSTGRES_DB=appsec
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://appsec:changeme@postgres:5432/appsec
DATABASE_URL_SYNC=postgresql+psycopg2://appsec:changeme@postgres:5432/appsec

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_SECRET_KEY=super-secret-change-me-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# App
APP_NAME=AppSec SaaS
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Domain verification
VERIFICATION_TOKEN_PREFIX=appsec-verify
VERIFICATION_TTL_DAYS=90
